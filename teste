<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard Geral CN/EPCAr · Matriz Educação</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
/* Estilos originais preservados */
:root{
  --bg:#f5f7fa;--white:#ffffff;--border:#e5e9f0;
  --text:#1a2332;--text2:#4b5a6e;--text3:#8b99ab;
  --navy:#1e3a5f;--navy2:#2d5282;
  --blue:#3b82f6;--blue-soft:#eff6ff;
  --green:#16a34a;--green-soft:#f0fdf4;
  --red:#dc2626;--red-soft:#fef2f2;
  --gold:#d97706;--gold-soft:#fffbeb;
  --shadow:0 1px 3px rgba(0,0,0,.08),0 4px 16px rgba(0,0,0,.06);
  --radius:14px;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',-apple-system,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;line-height:1.5;}
.page-wrap{max-width:1320px;margin:0 auto;padding:28px 20px;}
.site-header{background:var(--white);border-bottom:2px solid var(--border);padding:0 24px;position:sticky;top:0;z-index:100;box-shadow:0 2px 8px rgba(0,0,0,.06);}
.site-header-inner{max-width:1400px;margin:0 auto;display:flex;align-items:center;gap:16px;min-height:64px;padding:8px 0;flex-wrap:wrap;}
.logo{display:flex;align-items:center;gap:10px;font-weight:900;font-size:18px;color:var(--navy);letter-spacing:-.3px;flex-shrink:0;}
.logo-badge{width:36px;height:36px;background:var(--navy);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;}
.logo-sub{font-size:12px;font-weight:600;color:var(--text3);display:block;}
.main-nav{display:flex;gap:4px;flex:1;justify-content:flex-end;flex-wrap:wrap;}
.nav-btn{padding:7px 12px;background:transparent;border:1px solid transparent;border-radius:8px;font-size:12.5px;font-weight:700;color:var(--text2);cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:5px;white-space:nowrap;}
.nav-btn:hover{background:var(--bg);color:var(--navy);}
.nav-btn.active{background:var(--navy);color:#fff;border-color:var(--navy);}
.section{display:none;}.section.active{display:block;}
.page-intro{margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid var(--border);}
.page-intro h1{font-size:26px;font-weight:900;color:var(--navy);margin-bottom:4px;}
.page-intro p{font-size:14px;color:var(--text2);max-width:640px;}
.legend-box{background:#f0f6ff;border:1px solid #c3d9f5;border-left:4px solid var(--blue);border-radius:10px;padding:14px 18px;margin-bottom:20px;font-size:13px;color:var(--text2);display:flex;gap:24px;flex-wrap:wrap;align-items:flex-start;}
.legend-box strong{color:var(--navy);}
.legend-item{display:flex;align-items:center;gap:6px;white-space:nowrap;}
.legend-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.ranking-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:28px;box-shadow:var(--shadow);}
.ranking-table{width:100%;border-collapse:separate;border-spacing:0 6px;}
.ranking-table thead th{font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;padding:0 12px 8px;border-bottom:1.5px solid var(--border);}
.ranking-row td{padding:12px;background:var(--bg);border-radius:10px;}
.search-input{width:100%;max-width:400px;padding:10px 16px;border:1.5px solid var(--border);border-radius:9px;font-size:14px;background:var(--bg);margin-bottom:14px;}
/* ... (demais estilos omitidos para brevidade, mas mantidos no seu arquivo) ... */
</style>
</head>
<body>

<header class="site-header">
  <div class="site-header-inner">
    <div class="logo">
      <div class="logo-badge">⚓</div>
      <div>Dashboard Geral CN/EPCAr
        <span class="logo-sub">Simulados 2026 · Matriz Educação</span>
      </div>
    </div>
    <nav class="main-nav">
      <button class="nav-btn" onclick="goSec('emC',this)">🏆 CN Médio — Geral</button>
      <button class="nav-btn" onclick="goSec('9milC',this)">🎖️ 9° Militar — Geral</button>
      <button class="nav-btn" onclick="goSec('em',this)">📚 EM — 28/02</button>
      <button class="nav-btn" onclick="goSec('9mil',this)">🎓 9MIL — 28/02</button>
      <button class="nav-btn active" id="navEm21" onclick="goSec('em21',this)">📚 EM — 21/03</button>
      <button class="nav-btn" id="nav9mil21" onclick="goSec('9mil21',this)">🎓 9MIL — 21/03</button>
      <button class="nav-btn" onclick="goSec('epcar',this)">✈️ EPCAr — Geral</button>
      <button class="nav-btn" onclick="goSec('busca',this)">🔍 Buscar Aluno</button>
    </nav>
  </div>
</header>

<div id="em21Section" class="section active">
  <div class="page-wrap fade-in">
    <div class="page-intro">
      <h1>📚 Ranking Ensino Médio — Simulado 1º Dia · 21/03/2026</h1>
      <p>Classificação baseada no simulado de Matemática e Inglês realizados em 21 de março.</p>
    </div>
    <div class="legend-box">
      <strong>Parâmetros (CN 1º Dia):</strong>
      <div class="legend-item"><div class="legend-dot" style="background:#16a34a"></div>Mínimo: 10 acertos em Matemática e 10 em Inglês</div>
    </div>
    <div class="ranking-card">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:18px">
        <h2 style="font-size:18px;font-weight:900;color:var(--navy)">Lista de Alunos (Médio Militar)</h2>
        <input class="search-input" style="max-width:280px;margin:0" type="text" placeholder="🔍 Buscar aluno..." oninput="filtrarTabela('bodyEm21', this.value)">
      </div>
      <table class="ranking-table">
        <thead>
          <tr>
            <th style="width:60px">Pos.</th>
            <th style="text-align:left">Aluno</th>
            <th>Matemática (20q)</th>
            <th>Inglês (20q)</th>
            <th>Média</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="bodyEm21">
          <tr class="ranking-row">
            <td style="text-align:center">1º</td>
            <td><strong>PIETRO FERREIRA</strong><br><small>MD-2JR21</small></td>
            <td style="text-align:center">19</td>
            <td style="text-align:center">20</td>
            <td style="text-align:center">9,75</td>
            <td style="text-align:center"><span class="chip chip-aprov">Aprovado</span></td>
          </tr>
          </tbody>
      </table>
    </div>
  </div>
</div>

<div id="9mil21Section" class="section">
  <div class="page-wrap fade-in">
    <div class="page-intro">
      <h1>🎓 Ranking 9º Ano Militar — Simulado 1º Dia · 21/03/2026</h1>
      <p>Classificação baseada no simulado de Matemática e Inglês realizados em 21 de março.</p>
    </div>
    <div class="ranking-card">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:18px">
        <h2 style="font-size:18px;font-weight:900;color:var(--navy)">Lista de Alunos (9º Ano)</h2>
        <input class="search-input" style="max-width:280px;margin:0" type="text" placeholder="🔍 Buscar aluno..." oninput="filtrarTabela('body9mil21', this.value)">
      </div>
      <table class="ranking-table">
        <thead>
          <tr>
            <th style="width:60px">Pos.</th>
            <th style="text-align:left">Aluno</th>
            <th>Matemática (20q)</th>
            <th>Inglês (20q)</th>
            <th>Média</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="body9mil21">
          <tr class="ranking-row">
            <td style="text-align:center">1º</td>
            <td><strong>DAVI LIMA</strong><br><small>RM-1MIL91</small></td>
            <td style="text-align:center">15</td>
            <td style="text-align:center">17</td>
            <td style="text-align:center">8,00</td>
            <td style="text-align:center"><span class="chip chip-aprov">Aprovado</span></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
function goSec(id, btn) {
  // Esconde todas as seções
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  // Remove classe active de todos os botões
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  
  // Ativa a seção e o botão clicado
  document.getElementById(id + 'Section').classList.add('active');
  btn.classList.add('active');
}

function filtrarTabela(idCorpo, termo) {
  const linhas = document.getElementById(idCorpo).getElementsByTagName('tr');
  const filtro = termo.toLowerCase();
  for (let i = 0; i < linhas.length; i++) {
    const nome = linhas[i].getElementsByTagName('td')[1].textContent.toLowerCase();
    linhas[i].style.display = nome.includes(filtro) ? '' : 'none';
  }
}
</script>

</body>
</html>
